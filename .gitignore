# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- Local data (never commit — see DATA_SETUP.md) ---

# ARTISJUS / CMO raw exports (large CSVs, xlsx, Numbers)
/Artisjus azonosítatlan művek/

# Generated indexes & query catalogs (build on each machine)
/data/*
!/data/.gitkeep
/raw/
/exports/
*.duckdb
*.duckdb.wal
*.parquet

# MLC & other large raw dumps (any path)
**/unmatchedresources.tsv
*.tsv

# Derived pipeline outputs (regenerate via scripts/mlc/)
**/hu_artist_scans/

# Office / spreadsheet exports
*.xlsx
*.numbers

# Python
__pycache__/
*.py[cod]

# ARTISJUS search index (generated — npm run artisjus:build-index)
/data/artisjus-index.json
