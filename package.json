{
  "name": "blackbox_auditor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mlc:mb-artists": "python3 scripts/mlc/fetch_mb_hu_artists.py",
    "mlc:spotify-check": "python3 scripts/mlc/spotify_hu_crosscheck.py",
    "mlc:filter-non-hu": "python3 scripts/mlc/filter_non_hu_hungarian.py",
    "mlc:popular-artists": "python3 scripts/mlc/fetch_hu_popular_artists.py",
    "mlc:summary": "python3 scripts/mlc/summarize_isrc_conflicts.py",
    "artisjus:build-index": "node scripts/artisjus/build-index.mjs",
    "artisjus:smoke-leaderboard": "python3 scripts/artisjus/smoke_leaderboard.py",
    "cmo:build-index": ".venv/bin/python3 scripts/cmo/build_indexes.py",
    "cmo:gvl-extract-sendemeldungen": ".venv/bin/python3 scripts/cmo/gvl_extract_sendemeldungen.py",
    "cmo:bootstrap": ".venv/bin/python3 scripts/cmo/build_indexes.py --bootstrap",
    "cmo:fetch": ".venv/bin/python3 scripts/cmo/fetch_sources.py",
    "cmo:fetch-eau": ".venv/bin/python3 scripts/cmo/fetch_eau.py",
    "eji:search": "npx tsx scripts/cmo/search_eji.mts",
    "query-api:start": "npx tsx scripts/query-api/server.mts",
    "server:install": "bash scripts/server/install-macos-services.sh",
    "server:uninstall": "bash scripts/server/uninstall-macos-services.sh",
    "server:status": "bash scripts/server/status.sh",
    "server:tunnel-url": "bash scripts/server/tunnel-url.sh",
    "etl:parquet": ".venv/bin/python3 scripts/etl/tsv_to_parquet.py",
    "etl:catalog": ".venv/bin/python3 scripts/etl/build_catalog.py",
    "etl:artist-tokens": ".venv/bin/python3 scripts/etl/build_mlc_artist_tokens.py",
    "etl:artist-tokens:unmatched": "bash scripts/etl/run_unmatched_token_build.sh",
    "etl:artist-tokens:unmatched:resume": "bash scripts/etl/resume_unmatched_token_build.sh",
    "etl:isrc-index:unmatched": "bash scripts/etl/run_unmatched_isrc_index.sh",
    "etl:isrc-index": ".venv/bin/python3 scripts/etl/build_mlc_isrc_index.py",
    "etl:query": ".venv/bin/python3 scripts/etl/query.py",
    "etl:export-artist": ".venv/bin/python3 scripts/etl/export_artist_mlc_json.py",
    "db:migrate": "npx tsx scripts/db/migrate.mts",
    "batch:artist-audit": "npx tsx scripts/batch_artist_audit.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "papaparse": "^5.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
