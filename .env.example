# credits.fm — ajánlott `cfm_…` kulcs (x-api-key header). Kulcs nélkül is működik (alacsonyabb limit).
CREDITS_FM_API_KEY=

# Alapértelmezett: https://api.credits.fm/v1
CREDITS_FM_BASE_URL=https://api.credits.fm/v1

# Ha a v1 batch üres szerzőt ad, egészítsd ki a credits.fm legacy JSON-nel (GET /api/isrc/…).
CREDITS_FM_LEGACY_FALLBACK=true

# Legacy host (default: https://credits.fm)
CREDITS_FM_LEGACY_ORIGIN=https://credits.fm

# Legacy GET timeout (ms).
CREDITS_FM_LEGACY_TIMEOUT_MS=28000

# Üres szerzőlista után próbál GET /v1/isrc…?graph=1 és GET /v1/iswc…?graph=1 (lassabb / timeout veszély).
CREDITS_FM_GRAPH_HYDRATE=false

# Graph kérések timeout ms (Node AbortSignal.timeout).
CREDITS_FM_GRAPH_TIMEOUT_MS=14000

# Spotify Web API — keresőhöz kötelező (Client Credentials).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Előadó teljes dallista (albumok + megjelenések) — nagy előadóknál sok kérés; korlátok.
# SPOTIFY_DISCOGRAPHY_MARKET=US
# SPOTIFY_DISCOGRAPHY_MAX_ALBUMS=400
# SPOTIFY_DISCOGRAPHY_MAX_TRACKS=2500
