# credits.fm — ajánlott `cfm_…` kulcs (x-api-key header). Kulcs nélkül is működik (alacsonyabb limit).
CREDITS_FM_API_KEY=

# Alapértelmezett: https://api.credits.fm/v1
CREDITS_FM_BASE_URL=https://api.credits.fm/v1

# Ha a v1 batch üres szerzőt ad, egészítsd ki a credits.fm legacy JSON-nel (GET /api/isrc/…).
CREDITS_FM_LEGACY_FALLBACK=true

# Legacy host (default: https://credits.fm)
CREDITS_FM_LEGACY_ORIGIN=https://credits.fm

# Legacy GET timeout (ms).
CREDITS_FM_LEGACY_TIMEOUT_MS=28000

# Üres szerzőlista után próbál GET /v1/isrc…?graph=1 és GET /v1/iswc…?graph=1 (lassabb / timeout veszély).
CREDITS_FM_GRAPH_HYDRATE=false

# Graph kérések timeout ms (Node AbortSignal.timeout).
CREDITS_FM_GRAPH_TIMEOUT_MS=14000

# Spotify Web API — keresőhöz kötelező (Client Credentials).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Előadó teljes dallista (albumok + megjelenések) — nagy előadóknál sok kérés; korlátok.
# SPOTIFY_DISCOGRAPHY_MARKET=US
# SPOTIFY_DISCOGRAPHY_MAX_ALBUMS=400
# SPOTIFY_DISCOGRAPHY_MAX_TRACKS=2500

# --- Helyi adatpathok (gépenként más — lásd DATA_SETUP.md) ---
# ARTISJUS_CSV_PATH=/Volumes/Data/music-rights/raw/artisjus/artisjus_azonositatlan_muvek_2025.csv
# ARTISJUS_INDEX_PATH=./data/artisjus-index.json
# MLC_UNMATCHED_TSV=/Volumes/Data/music-rights/raw/mlc/unmatchedresources.tsv
# MLC_UNCLAIMED_TSV=/Volumes/Data/music-rights/raw/mlc/unclaimedmusicalworkrightshares.tsv
# MLC_HU_DATA_DIR=/Volumes/Data/music-rights/derived/mlc-hu
# MLC_ARTIST_SCAN_TIMEOUT_MS=600000

# DuckDB catalog (ETL output — npm run etl:parquet && npm run etl:catalog)
# CATALOG_PARQUET_DIR=./data/parquet
# CATALOG_DUCKDB_PATH=./data/catalog.duckdb
# MLC_USE_DUCKDB=true

# --- Későbbi online query backend (Vercel proxy → állandó API az adatgépen / VPS-en) ---
# QUERY_API_URL=https://your-tunnel-or-vps.example/search
# QUERY_API_KEY=

# credits.fm — opcionális, csak egyedi ISRC audit (Haladó menü). Az előadó-flow MLC TSV-t használ.
# MUSICBRAINZ_USER_AGENT=BlackboxAuditor/1.0 (you@example.com)
